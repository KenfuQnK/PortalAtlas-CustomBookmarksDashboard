{
    "manifest_version": 3,
    "name": "Portal Atlas",
    "version": "2.0.0",
    "description": "Custom Bookmarks Dashboard",
    "permissions": [
      "identity",
      "storage",
      "unlimitedStorage"
    ],
    "key": "",
    "oauth2": {
        "client_id": "280534041396-pvremqm026mhqgcsn848p3djmo3mcjiv.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/drive.appdata"
        ]
    },
    "host_permissions": [
        "<all_urls>"
    ],
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "icons": {
        "16": "icons/icon16.png",
        "24": "icons/icon48.png",
        "32": "icons/icon48.png",
        "48": "icons/icon48.png",
        "64": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "web_accessible_resources": [{
        "resources": ["lang/*.json"],
        "matches": ["<all_urls>"]
    }]
  }
